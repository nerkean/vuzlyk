<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle || 'Редагувати статтю' %> | Адмін-панель</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    
    <!-- Підключення шрифтів та іконок -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/admin.css">
    
    <style>
        /* Основний контейнер форми */
        .admin-form-container {
            max-width: 900px;
            margin: 0 auto;
            background: var(--bg-surface, #ffffff);
            border-radius: var(--radius-lg, 16px);
            box-shadow: var(--shadow-md, 0 4px 6px -1px rgba(0, 0, 0, 0.1));
            padding: 30px 40px;
        }

        /* Секції форми (використовуються у _form-fields) */
        .form-section {
            margin-bottom: 30px;
            padding-bottom: 25px;
            border-bottom: 1px solid var(--border-color, #e2e8f0);
        }
        .form-section:last-of-type { border-bottom: none; margin-bottom: 20px; }

        .form-section-title {
            font-size: 18px;
            color: var(--text-primary, #1e293b);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
        }
        .form-section-title i { color: var(--brand-primary, #b9936c); }

        /* Поля вводу та групи */
        .admin-form-group { margin-bottom: 20px; }
        .admin-form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 14px;
            color: var(--text-primary, #1e293b);
        }
        .admin-form-group .required { color: #ef4444; margin-left: 3px; }
        .admin-form-group small { color: var(--text-muted); display: block; margin-top: 4px; font-size: 12px; }

        /* Стилізація елементів вводу */
        .admin-form-control, 
        .admin-form-group input[type="text"], 
        .admin-form-group textarea {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color, #cbd5e1);
            border-radius: var(--radius-sm, 8px);
            font-family: inherit;
            font-size: 15px;
            color: var(--text-primary, #1e293b);
            background-color: #f8fafc;
            transition: all 0.2s ease;
            box-sizing: border-box;
        }

        .admin-form-control:focus, 
        .admin-form-group input:focus, 
        .admin-form-group textarea:focus {
            outline: none;
            border-color: var(--brand-primary, #b9936c);
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(185, 147, 108, 0.15);
        }

        /* Стилі для завантаження зображення */
        .file-upload-wrapper {
            border: 2px dashed var(--border-color, #cbd5e1);
            border-radius: var(--radius-md, 12px);
            padding: 24px;
            text-align: center;
            background-color: #f8fafc;
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }
        .file-upload-wrapper:hover {
            border-color: var(--brand-primary, #b9936c);
            background-color: #fff;
        }
        .file-upload-wrapper input[type="file"] {
            opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer;
        }
        .file-upload-content i { font-size: 28px; color: var(--text-muted, #94a3b8); margin-bottom: 10px; }
        
        .image-preview-item {
            position: relative; width: fit-content; max-width: 200px;
            border-radius: var(--radius-sm, 8px); border: 1px solid var(--border-color, #e2e8f0);
            overflow: hidden; box-shadow: var(--shadow-sm); margin-top: 15px;
        }
        .image-preview-item img { width: 100%; height: auto; object-fit: contain; display: block; }

        /* Чекбокси */
        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            background: #f8fafc;
            padding: 15px;
            border-radius: var(--radius-sm, 8px);
            border: 1px solid var(--border-color, #e2e8f0);
            transition: all 0.2s;
            font-weight: 500;
        }
        .checkbox-group label:hover { background: #f1f5f9; }
        .checkbox-group input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--brand-primary, #b9936c); }

        /* Дії та Небезпечна зона */
        .form-actions { display: flex; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--border-color, #e2e8f0); }
        .danger-zone { 
            margin-top: 40px; 
            padding: 25px; 
            border: 1px dashed #fee2e2; 
            border-radius: var(--radius-lg, 16px); 
            background: #fffcfc; 
        }

        /* Error Message */
        .error-message {
            background-color: #fee2e2;
            color: #b91c1c;
            padding: 15px;
            border-radius: var(--radius-sm);
            border-left: 4px solid #ef4444;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .form-actions { flex-direction: column; }
            .form-actions .btn { width: 100%; justify-content: center; text-align: center; }
            .admin-form-container { padding: 20px; }
        }
    </style>
</head>
<body class="admin-body">

    <!-- Бічна панель навігації (Sidebar) -->
    <aside class="admin-sidebar">
        <div class="sidebar-header">
            <i class="fa-solid fa-wand-magic-sparkles logo-icon"></i>
            <h2>Адмін-панель</h2>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/orders" class="nav-item">
                <i class="fa-solid fa-box-open"></i>
                <span>Замовлення</span>
            </a>
            <a href="/admin/products" class="nav-item">
                <i class="fa-solid fa-tags"></i>
                <span>Товари</span>
            </a>
            <a href="/admin/blog" class="nav-item active">
                <i class="fa-solid fa-pen-nib"></i>
                <span>Блог</span>
            </a>
            <a href="/admin/blog/html-guide" class="nav-item">
                <i class="fa-solid fa-code"></i>
                <span>HTML Інструкція</span>
            </a>
            
            <div class="nav-divider"></div>
            
            <a href="/admin/logout" class="nav-item logout">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Вийти</span>
            </a>
        </nav>
    </aside>

    <!-- Основний контент -->
    <div class="admin-content-wrapper">
        <!-- Верхня панель (Topbar) -->
        <header class="admin-topbar">
            <div class="topbar-left">
                <button id="mobileMenuBtn" class="mobile-menu-btn">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div style="font-weight: 500; color: var(--text-secondary);">
                    <a href="/admin/blog" style="color: inherit; text-decoration: none;">Блог</a> 
                    <i class="fa-solid fa-chevron-right" style="font-size: 10px; margin: 0 8px;"></i> 
                    Редагування статті
                </div>
            </div>
        </header>

        <main class="admin-main">
            <div class="container-fluid">
                <!-- Хедер сторінки -->
                <div class="page-header" style="margin-bottom: 20px;">
                    <div>
                        <h2 class="page-title"><%= pageTitle || 'Редагувати статтю' %></h2>
                    </div>
                </div>

                <% if (typeof post !== 'undefined' && post) { %>
                    <div class="admin-form-container">
                        <form action="/admin/blog/<%= post._id %>?_method=PUT" method="POST" enctype="multipart/form-data" id="postForm">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            
                            <!-- Підключення часткового шаблону з полями форми -->
                            <%- include('_form-fields', { post: post, errors: (typeof errors !== 'undefined' ? errors : null), formData: (typeof formData !== 'undefined' ? formData : post) }) %>
                            
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="savePostBtn" style="padding: 12px 24px; font-size: 16px;">
                                    <i class="fa-solid fa-save"></i> Оновити статтю
                                </button>
                                <a href="/admin/blog" class="btn btn-secondary" style="padding: 12px 24px; font-size: 16px;">
                                    <i class="fa-solid fa-rotate-left"></i> Скасувати
                                </a>
                            </div>
                        </form>

                        <div class="danger-zone">
                            <h4 style="color: #b91c1c; margin-bottom: 8px; font-weight: 700;"><i class="fa-solid fa-triangle-exclamation"></i> Небезпечна зона</h4>
                            <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 15px;">Будьте обережні: видалення статті неможливо скасувати. Зображення статті також буде видалено.</p>
                            <button type="button" id="deletePostBtn" class="btn btn-danger btn-sm">
                                <i class="fa-regular fa-trash-can"></i> Видалити статтю назавжди
                            </button>
                        </div>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa-solid fa-circle-question" style="font-size: 40px; margin-bottom: 15px; color: var(--text-muted);"></i>
                        <h3>Статтю не знайдено</h3>
                        <p>Можливо, вона була видалена або посилання невірне.</p>
                        <a href="/admin/blog" class="btn btn-primary" style="margin-top: 20px;">Повернутися до блогу</a>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- Модальне вікно видалення -->
    <div id="confirmationModal" class="modal-overlay" style="display: none;">
        <div class="modal-dialog">
            <div class="modal-content">
                <button class="close-button" type="button">&times;</button>
                <div class="modal-body text-center">
                    <div class="warning-icon-wrapper" style="color: #ef4444; background: #fee2e2;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h3 style="font-size: 20px; margin-bottom: 10px;">Видалити цю статтю?</h3>
                    <p class="modal-subtext">Ви дійсно впевнені, що хочете видалити статтю <strong><%= typeof post !== 'undefined' ? post.title : '' %></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button id="cancelActionBtn" class="btn btn-secondary" type="button">Скасувати</button>
                    <button id="confirmDeleteBtn" class="btn btn-danger" type="button">Так, видалити</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const postId = '<%= typeof post !== 'undefined' ? post._id : '' %>';
            const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

            // Мобільне меню
            const mobileBtn = document.getElementById('mobileMenuBtn');
            const sidebar = document.querySelector('.admin-sidebar');
            if (mobileBtn && sidebar) {
                mobileBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('active');
                });
            }

            // Анімація кнопки при збереженні
            const postForm = document.getElementById('postForm');
            const saveBtn = document.getElementById('savePostBtn');
            if (postForm && saveBtn) {
                postForm.addEventListener('submit', () => {
                    saveBtn.disabled = true;
                    saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Збереження...';
                });
            }

            // Логіка модального вікна видалення
            const modal = document.getElementById('confirmationModal');
            document.getElementById('deletePostBtn')?.addEventListener('click', () => {
                modal.style.display = 'flex';
                setTimeout(() => modal.classList.add('show'), 10);
            });

            const closeM = () => {
                modal.classList.remove('show');
                setTimeout(() => modal.style.display = 'none', 300);
            };
            
            modal?.querySelector('.close-button').addEventListener('click', closeM);
            document.getElementById('cancelActionBtn')?.addEventListener('click', closeM);
            window.addEventListener('click', (e) => { if (e.target === modal) closeM(); });

            document.getElementById('confirmDeleteBtn')?.addEventListener('click', async function() {
                if (!postId) return;
                
                this.disabled = true;
                this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Видаляємо...';
                
                try {
                    const res = await fetch(`/admin/blog/${postId}/delete`, {
                        method: 'POST',
                        headers: { 'CSRF-Token': csrfToken }
                    });
                    if(res.ok) {
                        window.location.href = '/admin/blog';
                    } else {
                        alert('Не вдалося видалити статтю.');
                        this.disabled = false;
                        this.innerHTML = 'Так, видалити';
                    }
                } catch(e) { 
                    console.error(e);
                    alert('Помилка підключення до сервера.');
                    this.disabled = false;
                    this.innerHTML = 'Так, видалити';
                }
            });
        });
    </script>
</body>
</html>