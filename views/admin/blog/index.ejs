<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Адмін-панель - Керування Блогом | Вузлик</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    
    <!-- Підключення шрифтів та іконок -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/admin.css">
    
    <style>
        .post-img-mini {
            width: 60px;
            height: 44px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid var(--border-color, #e2e8f0);
            box-shadow: var(--shadow-sm);
        }
        .post-img-placeholder {
            width: 60px;
            height: 44px;
            border-radius: 6px;
            background-color: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 18px;
            border: 1px dashed var(--border-color, #cbd5e1);
        }
        
        .post-info-cell {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .post-title-link {
            font-weight: 600;
            color: var(--text-primary);
            text-decoration: none;
            transition: color 0.2s ease;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .post-title-link:hover {
            color: var(--brand-primary);
        }

        .badge-status {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }
        .badge-published { background-color: #dcfce7; color: #15803d; }
        .badge-draft { background-color: #f1f5f9; color: #475569; }

        .tags-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
        }
        
        .tag-pill {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #475569;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
            white-space: nowrap;
        }

        .post-date {
            font-size: 13px;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .action-btn.edit-btn:hover { background-color: #e0f2fe; color: #0284c7; }
        
        .empty-icon-wrapper i {
            font-size: 48px;
            color: var(--brand-primary);
            opacity: 0.5;
        }
    </style>
</head>
<body class="admin-body">

    <!-- Бічна панель навігації (Sidebar) -->
    <aside class="admin-sidebar">
        <div class="sidebar-header">
            <i class="fa-solid fa-wand-magic-sparkles logo-icon"></i>
            <h2>Адмін-панель</h2>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/orders" class="nav-item">
                <i class="fa-solid fa-box-open"></i>
                <span>Замовлення</span>
            </a>
            <a href="/admin/products" class="nav-item">
                <i class="fa-solid fa-tags"></i>
                <span>Товари</span>
            </a>
            <a href="/admin/blog" class="nav-item active">
                <i class="fa-solid fa-pen-nib"></i>
                <span>Блог</span>
            </a>
            <a href="/admin/blog/html-guide" class="nav-item">
                <i class="fa-solid fa-code"></i>
                <span>HTML Інструкція</span>
            </a>
            
            <div class="nav-divider"></div>
            
            <a href="/admin/logout" class="nav-item logout">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Вийти</span>
            </a>
        </nav>
    </aside>

    <!-- Основний контент -->
    <div class="admin-content-wrapper">
        <!-- Верхня панель (Topbar) -->
        <header class="admin-topbar">
            <div class="topbar-left">
                <button id="mobileMenuBtn" class="mobile-menu-btn">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="search-bar">
                    <i class="fa-solid fa-search"></i>
                    <input type="text" id="postSearchInput" placeholder="Пошук статей за назвою чи тегами...">
                </div>
            </div>
            <div class="topbar-right">
                <!-- Місце для додаткових елементів хедера -->
            </div>
        </header>

        <main class="admin-main">
            <div class="container-fluid">
                <!-- Хедер сторінки -->
                <div class="page-header">
                    <div>
                        <h2 class="page-title">Керування блогом</h2>
                        <p class="page-subtitle">Створюйте нові публікації, редагуйте та публікуйте контент</p>
                    </div>
                    <div class="header-actions">
                        <a href="/admin/blog/new" class="btn btn-primary">
                            <i class="fa-solid fa-plus"></i> Додати статтю
                        </a>
                    </div>
                </div>

                <!-- Блок зі статистикою -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon" style="background-color: var(--brand-light); color: var(--brand-primary);">
                            <i class="fa-solid fa-newspaper"></i>
                        </div>
                        <div class="stat-details">
                            <p class="stat-title">Всього статей</p>
                            <h3 class="stat-value"><%= posts ? posts.length : 0 %></h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon done">
                            <i class="fa-solid fa-check-circle"></i>
                        </div>
                        <div class="stat-details">
                            <p class="stat-title">Опубліковано</p>
                            <h3 class="stat-value"><%= posts ? posts.filter(p => p.isPublished).length : 0 %></h3>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background-color: #f1f5f9; color: #64748b;">
                            <i class="fa-solid fa-file-pen"></i>
                        </div>
                        <div class="stat-details">
                            <p class="stat-title">Чернетки</p>
                            <h3 class="stat-value"><%= posts ? posts.filter(p => !p.isPublished).length : 0 %></h3>
                        </div>
                    </div>
                </div>

                <!-- Таблиця статей -->
                <div class="card table-card">
                    <div class="card-header">
                        <h3 class="card-title">Усі публікації <span id="visiblePostCount" style="font-size: 0.8em; color: var(--text-muted); font-weight: 400; margin-left: 8px;"></span></h3>
                        <div class="filter-group">
                            <select id="statusFilter" class="filter-select">
                                <option value="all">Усі статуси</option>
                                <option value="published">Опубліковано</option>
                                <option value="draft">Чернетка</option>
                            </select>
                        </div>
                    </div>

                    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                        <div class="table-responsive">
                            <table class="modern-table" id="postsTable">
                                <thead>
                                    <tr>
                                        <th>Стаття</th>
                                        <th>Теги</th>
                                        <th>Дата публікації</th>
                                        <th>Статус</th>
                                        <th class="text-right">Дії</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% posts.forEach((post, index) => { %>
                                        <tr class="table-row-animate post-row" style="animation-delay: <%= index * 0.05 %>s;">
                                            <td data-label="Стаття" style="max-width: 300px;">
                                                <div class="post-info-cell">
                                                    <% if (post.imageUrl) { %>
                                                        <img src="<%= post.imageUrl %>" alt="<%= post.title %>" class="post-img-mini" loading="lazy">
                                                    <% } else { %>
                                                        <div class="post-img-placeholder"><i class="fa-regular fa-image"></i></div>
                                                    <% } %>
                                                    <div>
                                                        <a href="/blog/<%= post.slug %>" target="_blank" class="post-title-link" title="Переглянути на сайті"><%= post.title %></a>
                                                    </div>
                                                </div>
                                            </td>
                                            <td data-label="Теги" class="post-tags-cell">
                                                <div class="tags-wrapper">
                                                    <% if (post.tags && post.tags.length > 0) { %>
                                                        <% post.tags.forEach(tag => { %>
                                                            <span class="tag-pill"><%= tag %></span>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <span class="text-muted">-</span>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td data-label="Дата публікації">
                                                <% if (post.isPublished && post.publishedAt) { %>
                                                    <div class="post-date">
                                                        <i class="fa-regular fa-calendar"></i> 
                                                        <%= new Date(post.publishedAt).toLocaleDateString('uk-UA', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                            <td data-label="Статус">
                                                <% if (post.isPublished) { %>
                                                    <span class="badge-status badge-published" data-status="published">Опубліковано</span>
                                                <% } else { %>
                                                    <span class="badge-status badge-draft" data-status="draft">Чернетка</span>
                                                <% } %>
                                            </td>
                                            <td data-label="Дії" class="text-right actions-cell">
                                                <a href="/admin/blog/<%= post._id %>/edit" class="action-btn edit-btn" title="Редагувати">
                                                    <i class="fa-regular fa-pen-to-square"></i>
                                                </a>
                                                
                                                <!-- Прихована форма для видалення -->
                                                <form id="delete-form-<%= post._id %>" action="/admin/blog/<%= post._id %>/delete" method="POST" style="display: none;">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                </form>
                                                
                                                <% var safeTitle = post.title.replace(/"/g, '&quot;'); %>
                                                <button type="button" class="action-btn delete-btn trigger-delete" data-post-id="<%= post._id %>" data-post-title="<%= safeTitle %>" title="Видалити">
                                                    <i class="fa-regular fa-trash-can"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                            <div id="noResultsMessage" style="display: none; text-align: center; padding: 40px; color: var(--text-muted);">
                                <i class="fa-solid fa-search" style="font-size: 2em; margin-bottom: 10px; opacity: 0.5;"></i>
                                <p>За вашим запитом статей не знайдено.</p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-icon-wrapper">
                                <i class="fa-solid fa-pen-nib"></i>
                            </div>
                            <h3>Блог поки що порожній</h3>
                            <p>Створіть свою першу статтю, щоб ділитися новинами та історіями з клієнтами.</p>
                            <a href="/admin/blog/new" class="btn btn-primary" style="margin-top: 15px;">
                                <i class="fa-solid fa-plus"></i> Написати статтю
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <!-- Модальне вікно підтвердження видалення статті -->
    <div id="confirmationModal" class="modal-overlay" style="display: none;">
        <div class="modal-dialog">
            <div class="modal-content">
                <button class="close-button">&times;</button>
                <div class="modal-body text-center">
                    <div class="warning-icon-wrapper" style="color: #ef4444; background-color: #fee2e2;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h3 id="confirmationMessage">Видалити статтю?</h3>
                    <p class="modal-subtext" id="confirmationSubtext">Ця дія видалить статтю з бази назавжди.</p>
                </div>
                <div class="modal-footer">
                    <button id="cancelActionBtn" class="btn btn-secondary">Скасувати</button>
                    <button id="confirmActionBtn" class="btn btn-danger">Видалити назавжди</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- Мобільне меню ---
            const mobileBtn = document.getElementById('mobileMenuBtn');
            const sidebar = document.querySelector('.admin-sidebar');
            
            if (mobileBtn && sidebar) {
                mobileBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('active');
                });
            }

            // --- Пошук та Фільтрація ---
            const searchInput = document.getElementById('postSearchInput');
            const statusFilter = document.getElementById('statusFilter');
            const postRows = document.querySelectorAll('.post-row');
            const noResultsMessage = document.getElementById('noResultsMessage');
            const visiblePostCount = document.getElementById('visiblePostCount');
            const postsTable = document.getElementById('postsTable');

            const filterPosts = () => {
                if (!postRows.length) return;
                
                const searchTerm = searchInput.value.toLowerCase().trim();
                const filterStatus = statusFilter.value;
                let visibleCount = 0;

                postRows.forEach(row => {
                    const postTitle = row.querySelector('.post-title-link').textContent.toLowerCase();
                    const postTags = row.querySelector('.post-tags-cell').textContent.toLowerCase();
                    const statusBadge = row.querySelector('.badge-status');
                    const postStatus = statusBadge ? statusBadge.getAttribute('data-status') : '';

                    const matchesSearch = postTitle.includes(searchTerm) || postTags.includes(searchTerm);
                    const matchesStatus = filterStatus === 'all' || postStatus === filterStatus;

                    if (matchesSearch && matchesStatus) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                if (noResultsMessage && postsTable) {
                    noResultsMessage.style.display = visibleCount === 0 ? 'block' : 'none';
                    postsTable.querySelector('thead').style.display = visibleCount === 0 ? 'none' : '';
                }
                
                if (searchTerm !== '' || filterStatus !== 'all') {
                    visiblePostCount.textContent = `(Знайдено: ${visibleCount})`;
                } else {
                    visiblePostCount.textContent = '';
                }
            };

            if (searchInput) searchInput.addEventListener('input', filterPosts);
            if (statusFilter) statusFilter.addEventListener('change', filterPosts);


            // --- Логіка Модального Вікна Видалення ---
            const modal = document.getElementById('confirmationModal');
            if (!modal) return;
            
            const closeButton = modal.querySelector('.close-button');
            const confirmBtn = document.getElementById('confirmActionBtn');
            const cancelBtn = document.getElementById('cancelActionBtn');
            const confirmationSubtext = document.getElementById('confirmationSubtext');
            
            let formToSubmitId = null; 

            const showModal = (postId, postTitle) => {
                formToSubmitId = `delete-form-${postId}`;
                confirmationSubtext.innerHTML = `Ви впевнені, що хочете видалити статтю <strong>«${postTitle}»</strong>? Цю дію неможливо скасувати.`;
                
                modal.style.display = 'flex';
                setTimeout(() => modal.classList.add('show'), 10);
            };

            const closeModal = () => {
                modal.classList.remove('show');
                setTimeout(() => {
                    modal.style.display = 'none';
                    formToSubmitId = null; 
                }, 300); 
            };

            // Слухачі на всі кнопки видалення (кошики)
            const deleteButtons = document.querySelectorAll('.trigger-delete');
            deleteButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const postId = btn.getAttribute('data-post-id');
                    const postTitle = btn.getAttribute('data-post-title');
                    showModal(postId, postTitle);
                });
            });

            // Підтвердження у модальному вікні
            if(confirmBtn) confirmBtn.addEventListener('click', () => {
                if (formToSubmitId) {
                    const form = document.getElementById(formToSubmitId);
                    if(form) {
                        // Анімація на кнопці під час сабміту
                        confirmBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Видалення...';
                        confirmBtn.disabled = true;
                        form.submit();
                    }
                }
            });

            if(cancelBtn) cancelBtn.addEventListener('click', closeModal);
            if(closeButton) closeButton.addEventListener('click', closeModal);
            window.addEventListener('click', (event) => { 
                if (event.target == modal) closeModal();
            });

            // Анімація появи рядків при завантаженні (каскадна)
            const rows = document.querySelectorAll('.table-row-animate');
            rows.forEach((row, index) => {
                setTimeout(() => {
                    row.style.opacity = '1';
                    row.style.transform = 'translateY(0)';
                }, 50 * index);
            });
        });
    </script>
</body>
</html>