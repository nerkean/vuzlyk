<%# views/admin/blog/_form-fields.ejs %>

<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <div class="error-message">
        <i class="fa-solid fa-circle-exclamation" style="margin-top: 3px;"></i>
        <div>
            <strong style="display: block; margin-bottom: 5px;">Помилка! Будь ласка, виправте наступні недоліки:</strong>
            <ul style="margin: 0; padding-left: 20px;">
                <% errors.forEach(error => { %>
                    <li><%= error.msg %></li>
                <% }); %>
            </ul>
        </div>
    </div>
<% } %>

<!-- СЕКЦІЯ 1: КОНТЕНТ СТАТТІ -->
<div class="form-section">
    <h3 class="form-section-title"><i class="fa-solid fa-pen-to-square"></i> Контент статті</h3>

    <div class="admin-form-group">
        <label for="title">Заголовок статті <span class="required">*</span></label>
        <input type="text" id="title" name="title" class="admin-form-control" placeholder="Введіть інтригуючий заголовок..." value="<%= typeof formData !== 'undefined' && formData.title ? formData.title : (typeof post !== 'undefined' && post.title ? post.title : '') %>" required>
    </div>

    <div class="admin-form-group">
        <label for="summary">Короткий опис (для списку статей) <span class="required">*</span></label>
        <textarea id="summary" name="summary" class="admin-form-control" rows="3" placeholder="Цей текст відображатиметься в картці статті на сторінці блогу..." required><%= typeof formData !== 'undefined' && formData.summary ? formData.summary : (typeof post !== 'undefined' && post.summary ? post.summary : '') %></textarea>
        <small>Максимум 200-250 символів.</small>
    </div>

    <div class="admin-form-group">
        <label for="content">Повний текст статті <span class="required">*</span></label>
        <textarea id="content" name="content" class="admin-form-control" rows="15" placeholder="Напишіть вашу статтю тут..." required><%= typeof formData !== 'undefined' && formData.content ? formData.content : (typeof post !== 'undefined' && post.content ? post.content : '') %></textarea>
        <small>Тут можна використовувати HTML-теги для форматування (наприклад, &lt;strong&gt;жирний&lt;/strong&gt;, &lt;h2&gt;заголовок&lt;/h2&gt;). Дивіться <a href="/admin/blog/html-guide" target="_blank" style="color: var(--brand-primary); text-decoration: underline;">HTML Інструкцію</a>.</small>
    </div>
</div>

<!-- СЕКЦІЯ 2: МЕДІА ТА ТЕГИ -->
<div class="form-section">
    <h3 class="form-section-title"><i class="fa-regular fa-image"></i> Медіа та теги</h3>

    <div class="admin-form-group">
        <label for="imageFile">Головне зображення статті</label>
        
        <% if (typeof post !== 'undefined' && post.imageUrl) { %>
            <div style="margin-bottom: 15px;">
                <label style="font-weight: normal; font-size: 13px;">Поточне зображення:</label>
                <div class="image-preview-item" style="margin-top: 5px; height: auto;">
                    <img src="<%= post.imageUrl %>?v=<%= new Date().getTime() %>" alt="Поточне зображення" style="height: 120px;">
                </div>
                <div class="checkbox-group" style="margin-top: 10px;">
                    <label style="padding: 10px; font-size: 13px; color: #b91c1c;">
                        <input type="checkbox" name="deleteCurrentImage" value="true"> 
                        <span>Видалити поточне зображення</span>
                    </label>
                </div>
            </div>
        <% } %>

        <div class="file-upload-wrapper">
            <input type="file" id="imageFile" name="imageFile" accept="image/jpeg, image/png, image/gif, image/webp">
            <div class="file-upload-content">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <p style="margin: 0 0 5px; font-weight: 500;">Натисніть для завантаження</p>
                <small id="file-chosen-blog">Рекомендований розмір: 800x400px (JPG, PNG, WEBP)</small>
            </div>
        </div>
        <div id="newImagePreview" class="image-preview-item" style="display: none; height: auto;">
            <img id="previewImg" src="" alt="Прев'ю" style="height: 120px;">
        </div>
    </div>

    <div class="admin-form-group">
        <label for="tags">Теги <small>(через кому)</small></label>
        <input type="text" id="tags" name="tags" class="admin-form-control" placeholder="Напр: історія, традиції, знижки" value="<%= typeof formData !== 'undefined' && formData.tags ? (Array.isArray(formData.tags) ? formData.tags.join(', ') : formData.tags) : (typeof post !== 'undefined' && post.tags ? post.tags.join(', ') : '') %>">
    </div>
</div>

<!-- СЕКЦІЯ 3: SEO -->
<div class="form-section">
    <h3 class="form-section-title"><i class="fa-solid fa-magnifying-glass-chart"></i> SEO налаштування</h3>

    <div class="admin-form-group">
        <label for="metaTitle">Meta Title (для пошукових систем)</label>
        <div style="display: flex; gap: 10px;">
            <input type="text" id="metaTitle" name="metaTitle" class="admin-form-control" placeholder="Заголовок для Google..." value="<%= typeof formData !== 'undefined' && formData.metaTitle ? formData.metaTitle : (typeof post !== 'undefined' && post.metaTitle ? post.metaTitle : '') %>">
            <button type="button" id="generateMetaTitleBtn" class="btn btn-secondary" title="Згенерувати AI">
                <i class="fa-solid fa-wand-magic-sparkles"></i> AI
            </button>
        </div>
        <small>Оптимальна довжина 50-60 символів. Якщо порожньо, використовується заголовок статті.</small>
    </div>

    <div class="admin-form-group">
        <label for="metaDescription">Meta Description</label>
        <div style="display: flex; gap: 10px;">
            <textarea id="metaDescription" name="metaDescription" class="admin-form-control" rows="2" maxlength="170" placeholder="Короткий опис для пошуку (до 160 симв.)"><%= typeof formData !== 'undefined' && formData.metaDescription ? formData.metaDescription : (typeof post !== 'undefined' && post.metaDescription ? post.metaDescription : '') %></textarea>
            <button type="button" id="generateMetaDescBtn" class="btn btn-secondary" title="Згенерувати AI">
                <i class="fa-solid fa-wand-magic-sparkles"></i> AI
            </button>
        </div>
        <div id="metaDescCounterBlog" style="font-size: 12px; margin-top: 5px; color: var(--text-muted);">0 / 160 символів</div>
    </div>
</div>

<!-- СЕКЦІЯ 4: ПУБЛІКАЦІЯ -->
<div class="form-section" style="margin-bottom: 0;">
    <div class="admin-form-group checkbox-group">
        <label>
            <input type="checkbox" id="isPublished" name="isPublished" <% if ((typeof formData !== 'undefined' && formData.isPublished === 'on') || (typeof post !== 'undefined' && post.isPublished)) { %>checked<% } %>>
            <span><strong>Опублікувати статтю зараз</strong><br>
            <small style="margin: 0; color: var(--text-secondary);">Якщо зняти галочку, стаття збережеться як чернетка і не буде видима клієнтам.</small></span>
        </label>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Отримуємо CSRF токен зі сторінки для AJAX запитів
        const getCsrfToken = () => {
            const metaTag = document.querySelector('meta[name="csrf-token"]');
            return metaTag ? metaTag.getAttribute('content') : document.querySelector('input[name="_csrf"]')?.value;
        };

        // --- Візуальне прев'ю вибраного зображення ---
        const imageFileInputBlog = document.getElementById('imageFile');
        const fileChosenSpanBlog = document.getElementById('file-chosen-blog');
        const newImagePreview = document.getElementById('newImagePreview');
        const previewImg = document.getElementById('previewImg');

        if (imageFileInputBlog) {
            imageFileInputBlog.addEventListener('change', function(){
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    fileChosenSpanBlog.textContent = `Вибрано файл: ${file.name}`;
                    
                    // Показуємо картинку
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        previewImg.src = e.target.result;
                        newImagePreview.style.display = 'block';
                    }
                    reader.readAsDataURL(file);
                } else {
                    fileChosenSpanBlog.textContent = 'Рекомендований розмір: 800x400px (JPG, PNG, WEBP)';
                    newImagePreview.style.display = 'none';
                    previewImg.src = '';
                }
            });
        }

        // --- Лічильник символів Meta Description ---
        const metaDescTextareaBlog = document.getElementById('metaDescription');
        const metaDescCounterBlog = document.getElementById('metaDescCounterBlog');
        const metaDescMaxLengthBlog = 160;

        function updateMetaCounterBlog() {
            if (!metaDescTextareaBlog || !metaDescCounterBlog) return;
            const currentLength = metaDescTextareaBlog.value.length;
            metaDescCounterBlog.textContent = `${currentLength} / ${metaDescMaxLengthBlog} символів`;
            if (currentLength > metaDescMaxLengthBlog) {
                metaDescCounterBlog.style.color = '#ef4444'; // червоний
            } else if (currentLength > metaDescMaxLengthBlog - 20) {
                metaDescCounterBlog.style.color = '#f59e0b'; // помаранчевий
            } else {
                metaDescCounterBlog.style.color = 'var(--text-muted)';
            }
        }

        if (metaDescTextareaBlog) {
            metaDescTextareaBlog.addEventListener('input', updateMetaCounterBlog);
            updateMetaCounterBlog(); // Initial call
        }

        // --- Генерація Meta Title AI ---
        const generateMetaTitleBtn = document.getElementById('generateMetaTitleBtn');
        const articleTitleInput = document.getElementById('title'); 
        const metaTitleInput = document.getElementById('metaTitle');

        if (generateMetaTitleBtn && articleTitleInput && metaTitleInput) {
            generateMetaTitleBtn.addEventListener('click', async function() {
                const articleTitle = articleTitleInput.value.trim();
                const articleSummary = document.getElementById('summary')?.value.trim() || '';
                const articleContent = document.getElementById('content')?.value.trim() || '';

                if (!articleTitle && !articleSummary && !articleContent) {
                    alert('Будь ласка, введіть заголовок, короткий опис або текст статті для генерації.');
                    return;
                }
                
                const originalButtonText = this.innerHTML;
                this.disabled = true;
                this.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;

                try {
                    const response = await fetch('/admin/blog/generate-meta-tags', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'CSRF-Token': getCsrfToken() // Додано токен!
                        },
                        body: JSON.stringify({ articleTitle, articleSummary, articleContent })
                    });
                    
                    if (!response.ok) {
                        const errorData = await response.json().catch(() => ({}));
                        throw new Error(errorData.message || `Помилка сервера: ${response.status}`);
                    }
                    
                    const data = await response.json();
                    if (data.metaTitle) {
                        metaTitleInput.value = data.metaTitle;
                        metaTitleInput.style.borderColor = 'var(--brand-primary)';
                        setTimeout(() => metaTitleInput.style.borderColor = '', 1000);
                    }
                } catch (error) {
                    console.error('Помилка генерації Meta Title:', error);
                    alert(`Помилка: ${error.message}`);
                } finally {
                    this.disabled = false;
                    this.innerHTML = originalButtonText;
                }
            });
        }

        // --- Генерація Meta Description AI ---
        const generateMetaDescBtnBlog = document.getElementById('generateMetaDescBtn');

        if (generateMetaDescBtnBlog && articleTitleInput && metaDescTextareaBlog) {
            generateMetaDescBtnBlog.addEventListener('click', async function() {
                const articleTitle = articleTitleInput.value.trim();
                const articleSummary = document.getElementById('summary')?.value.trim() || '';
                const articleContent = document.getElementById('content')?.value.trim() || '';

                if (!articleTitle && !articleSummary && !articleContent) {
                    alert('Будь ласка, введіть заголовок, короткий опис або текст статті для генерації.');
                    return;
                }

                const originalButtonText = this.innerHTML;
                this.disabled = true;
                this.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;

                try {
                    const response = await fetch('/admin/blog/generate-meta-tags', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'CSRF-Token': getCsrfToken() // Додано токен!
                        },
                        body: JSON.stringify({ articleTitle, articleSummary, articleContent })
                    });
                    
                    if (!response.ok) {
                        const errorData = await response.json().catch(() => ({}));
                        throw new Error(errorData.message || `Помилка сервера: ${response.status}`);
                    }
                    
                    const data = await response.json();
                    if (data.metaDescription) {
                        metaDescTextareaBlog.value = data.metaDescription;
                        updateMetaCounterBlog();
                        metaDescTextareaBlog.style.borderColor = 'var(--brand-primary)';
                        setTimeout(() => metaDescTextareaBlog.style.borderColor = '', 1000);
                    }
                     if (data.metaTitle && !metaTitleInput.value) { 
                        metaTitleInput.value = data.metaTitle;
                    }
                } catch (error) {
                    console.error('Помилка генерації Meta Description:', error);
                    alert(`Помилка: ${error.message}`);
                } finally {
                    this.disabled = false;
                    this.innerHTML = originalButtonText;
                }
            });
        }
    });
</script>