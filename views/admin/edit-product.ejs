<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> - Адмін-панель</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
    
    <!-- Підключення шрифтів та іконок -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">
    
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/admin.css">
    
    <style>
        /* Основний контейнер форми */
        .admin-form-container {
            max-width: 900px;
            margin: 0 auto;
            background: var(--bg-surface, #ffffff);
            border-radius: var(--radius-lg, 16px);
            box-shadow: var(--shadow-md, 0 4px 6px -1px rgba(0, 0, 0, 0.1));
            padding: 30px 40px;
        }

        /* Секції форми */
        .form-section {
            margin-bottom: 30px;
            padding-bottom: 25px;
            border-bottom: 1px solid var(--border-color, #e2e8f0);
        }
        .form-section:last-of-type { border-bottom: none; margin-bottom: 20px; }

        .form-section-title {
            font-size: 18px;
            color: var(--text-primary, #1e293b);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
        }
        .form-section-title i { color: var(--brand-primary, #b9936c); }

        /* Поля вводу та групи */
        .admin-form-group { margin-bottom: 20px; }
        .admin-form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 14px;
            color: var(--text-primary, #1e293b);
        }
        .admin-form-group .required { color: #ef4444; margin-left: 3px; }

        /* Стилізація самих елементів вводу */
        .admin-form-control, 
        .admin-form-group input[type="text"], 
        .admin-form-group input[type="number"], 
        .admin-form-group textarea, 
        .admin-form-group select {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color, #cbd5e1);
            border-radius: var(--radius-sm, 8px);
            font-family: inherit;
            font-size: 15px;
            color: var(--text-primary, #1e293b);
            background-color: #f8fafc;
            transition: all 0.2s ease;
            box-sizing: border-box;
        }

        .admin-form-control:focus, 
        .admin-form-group input:focus, 
        .admin-form-group textarea:focus, 
        .admin-form-group select:focus {
            outline: none;
            border-color: var(--brand-primary, #b9936c);
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(185, 147, 108, 0.15);
        }

        .form-row { display: flex; gap: 20px; }
        .form-row .admin-form-group { flex: 1; }

        /* Стилі для існуючих зображень */
        .current-images-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }
        .current-image-card {
            position: relative;
            border-radius: var(--radius-sm, 8px);
            border: 1px solid var(--border-color, #e2e8f0);
            overflow: hidden;
            background: #fff;
            box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.05));
        }
        .current-image-card img, .current-image-card video {
            width: 100%;
            height: 110px;
            object-fit: cover;
            display: block;
        }
        .delete-overlay {
            padding: 8px;
            background: #f8fafc;
            border-top: 1px solid var(--border-color, #e2e8f0);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        .delete-overlay input { width: 14px; height: 14px; cursor: pointer; }
        .delete-overlay:hover { background: #fee2e2; color: #b91c1c; }

        /* Стилі для завантаження */
        .file-upload-wrapper {
            border: 2px dashed var(--border-color, #cbd5e1);
            border-radius: var(--radius-md, 12px);
            padding: 24px;
            text-align: center;
            background-color: #f8fafc;
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }
        .file-upload-wrapper:hover {
            border-color: var(--brand-primary, #b9936c);
            background-color: #fff;
        }
        .file-upload-wrapper input[type="file"] {
            opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer;
        }
        .file-upload-content i { font-size: 28px; color: var(--text-muted, #94a3b8); margin-bottom: 10px; }

        /* Прев'ю нових фото */
        .image-preview-container { display: flex; flex-wrap: wrap; gap: 15px; margin-top: 15px; }
        .image-preview-item {
            position: relative; width: 100px; height: 100px;
            border-radius: var(--radius-sm, 8px); border: 1px solid var(--border-color, #e2e8f0);
            overflow: hidden; box-shadow: var(--shadow-sm);
        }
        .image-preview-item img, .image-preview-item video { width: 100%; height: 100%; object-fit: cover; }
        .btn-remove-preview {
            position: absolute; top: 4px; right: 4px;
            background: rgba(220, 38, 38, 0.9); color: white; border: none;
            width: 24px; height: 24px; border-radius: 50%; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px;
        }

        /* Чекбокси */
        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            background: #f8fafc;
            padding: 15px;
            border-radius: var(--radius-sm, 8px);
            border: 1px solid var(--border-color, #e2e8f0);
            transition: all 0.2s;
            font-weight: 500;
        }
        .checkbox-group label:hover { background: #f1f5f9; }
        .checkbox-group input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--brand-primary, #b9936c); }

        /* Дії */
        .form-actions { display: flex; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--border-color, #e2e8f0); }
        .danger-zone { 
            margin-top: 40px; 
            padding: 25px; 
            border: 1px dashed #fee2e2; 
            border-radius: var(--radius-lg, 16px); 
            background: #fffcfc; 
        }

        /* SEO Input Group */
        .seo-input-group {
            display: flex;
            gap: 10px;
            align-items: flex-start;
        }
        .seo-input-group textarea { flex: 1; min-height: 80px; }

        @media (max-width: 768px) {
            .form-row { flex-direction: column; gap: 0; }
            .form-actions { flex-direction: column; }
            .form-actions .btn { width: 100%; justify-content: center; }
            .admin-form-container { padding: 20px; }
            .seo-input-group { flex-direction: column; }
            .seo-input-group .btn { width: 100%; }
        }
    </style>
</head>
<body class="admin-body">

    <aside class="admin-sidebar">
        <div class="sidebar-header">
            <i class="fa-solid fa-wand-magic-sparkles logo-icon"></i>
            <h2>Адмін-панель</h2>
        </div>
        <nav class="sidebar-nav">
            <a href="/admin/orders" class="nav-item">
                <i class="fa-solid fa-box-open"></i>
                <span>Замовлення</span>
            </a>
            <a href="/admin/products" class="nav-item active">
                <i class="fa-solid fa-tags"></i>
                <span>Товари</span>
            </a>
            <a href="/admin/blog" class="nav-item">
                <i class="fa-solid fa-pen-nib"></i>
                <span>Блог</span>
            </a>
            <a href="/admin/blog/html-guide" class="nav-item">
                <i class="fa-solid fa-code"></i>
                <span>HTML Інструкція</span>
            </a>
            <div class="nav-divider"></div>
            <a href="/admin/logout" class="nav-item logout">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Вийти</span>
            </a>
        </nav>
    </aside>

    <div class="admin-content-wrapper">
        <header class="admin-topbar">
            <div class="topbar-left">
                <button id="mobileMenuBtn" class="mobile-menu-btn"><i class="fa-solid fa-bars"></i></button>
                <div style="font-weight: 500; color: var(--text-secondary);">
                    <a href="/admin/products" style="color: inherit; text-decoration: none;">Товари</a> 
                    <i class="fa-solid fa-chevron-right" style="font-size: 10px; margin: 0 8px;"></i> 
                    Редагування товару
                </div>
            </div>
        </header>

        <main class="admin-main">
            <div class="container-fluid">
                <div class="page-header" style="margin-bottom: 20px;">
                    <h2 class="page-title"><%= pageTitle %></h2>
                </div>

                <% if (locals.error || locals.errorMessage) { %>
                    <div class="error-message" style="margin-bottom: 20px;">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= locals.errorMessage || locals.error %></span>
                    </div>
                <% } %>

                <% if (typeof productData !== 'undefined' && productData) { %>
                    <div class="admin-form-container">
                        <form id="editProductForm">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            
                            <!-- ОСНОВНА ІНФОРМАЦІЯ -->
                            <div class="form-section">
                                <h3 class="form-section-title"><i class="fa-solid fa-circle-info"></i> Основна інформація</h3>
                                <div class="admin-form-group">
                                    <label for="name">Назва товару <span class="required">*</span></label>
                                    <input type="text" id="name" name="name" required value="<%= productData.name %>" placeholder="Введіть назву...">
                                </div>
                                <div class="admin-form-group">
                                    <label for="description">Опис товару <span class="required">*</span></label>
                                    <textarea id="description" name="description" rows="6" required placeholder="Опишіть ваш виріб..."><%= productData.description %></textarea>
                                </div>
                                <div class="form-row">
                                    <div class="admin-form-group">
                                        <label for="category">Категорія <span class="required">*</span></label>
                                        <select name="category" id="category">
                                            <option value="Вишивка" <%= productData.category === 'Вишивка' ? 'selected' : '' %>>Вишивка</option>
                                            <option value="Аксесуари" <%= productData.category === 'Аксесуари' ? 'selected' : '' %>>Аксесуари</option>
                                        </select>
                                    </div>
                                    <div class="admin-form-group">
                                        <label for="sku">SKU (Артикул)</label>
                                        <input type="text" id="sku" name="sku" value="<%= productData.sku || '' %>" placeholder="Напр: VSH-001">
                                    </div>
                                </div>
                            </div>

                            <!-- ЦІНА ТА СТАТУС -->
                            <div class="form-section">
                                <h3 class="form-section-title"><i class="fa-solid fa-tag"></i> Ціна та наявність</h3>
                                <div class="form-row">
                                    <div class="admin-form-group">
                                        <label for="price">Основна ціна (грн) <span class="required">*</span></label>
                                        <input type="number" id="price" name="price" required step="0.01" value="<%= productData.price %>" placeholder="0.00">
                                    </div>
                                    <div class="admin-form-group">
                                        <label for="maxPrice">Макс. ціна (грн) <small>(необов'язково)</small></label>
                                        <input type="number" id="maxPrice" name="maxPrice" step="0.01" value="<%= productData.maxPrice || '' %>" placeholder="0.00">
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="admin-form-group">
                                        <label for="status">Статус товару <span class="required">*</span></label>
                                        <select id="status" name="status" required>
                                            <option value="Під замовлення" <%= productData.status === 'Під замовлення' ? 'selected' : '' %>>Під замовлення</option>
                                            <option value="В наявності" <%= productData.status === 'В наявності' ? 'selected' : '' %>>В наявності</option>
                                            <option value="Немає в наявності" <%= productData.status === 'Немає в наявності' ? 'selected' : '' %>>Немає в наявності</option>
                                        </select>
                                    </div>
                                    <div class="admin-form-group">
                                        <label for="creation_time_info">Термін виготовлення <span class="required">*</span></label>
                                        <input type="text" id="creation_time_info" name="creation_time_info" required value="<%= productData.creation_time_info || '' %>" placeholder="Напр: 5-7 днів">
                                    </div>
                                </div>
                            </div>

                            <!-- МЕДІА -->
                            <div class="form-section">
                                <h3 class="form-section-title"><i class="fa-regular fa-images"></i> Медіафайли</h3>
                                
                                <label style="margin-bottom: 10px; display: block; font-weight: 600; font-size: 14px;">Поточні зображення <small>(відмітьте для видалення)</small></label>
                                <div class="current-images-grid">
                                    <% if(productData.images && productData.images.length > 0) { %>
                                        <% productData.images.forEach((imgSet, index) => { %>
                                            <div class="current-image-card">
                                                <img src="<%= imgSet.thumb.url %>" alt="Фото">
                                                <label class="delete-overlay">
                                                    <input type="checkbox" name="images_to_delete" value="<%= imgSet.large.public_id %>,<%= imgSet.medium.public_id %>,<%= imgSet.thumb.public_id %>">
                                                    <span>Видалити</span>
                                                </label>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <p style="color: var(--text-muted); font-size: 13px;">Зображення відсутні</p>
                                    <% } %>
                                </div>

                                <div class="admin-form-group">
                                    <label>Додати нові фото</label>
                                    <div class="file-upload-wrapper">
                                        <input type="file" id="imageFiles" name="imageFiles" multiple accept="image/*">
                                        <div class="file-upload-content">
                                            <i class="fa-solid fa-cloud-arrow-up"></i>
                                            <p>Оберіть нові файли</p>
                                            <small>JPG, PNG або WEBP (макс. 10MB)</small>
                                        </div>
                                    </div>
                                    <div class="image-preview-container" id="newImagePreview"></div>
                                </div>

                                <div class="admin-form-group" style="margin-top: 30px;">
                                    <label>Поточне "живе" фото (відео/GIF)</label>
                                    <% if (productData.livePhotoUrl) { %>
                                        <div class="current-image-card" style="width: 120px;">
                                            <% if (productData.livePhotoUrl.endsWith('.mp4') || productData.livePhotoUrl.endsWith('.webm')) { %>
                                                <video src="<%= productData.livePhotoUrl %>" muted loop autoplay></video>
                                            <% } else { %>
                                                <img src="<%= productData.livePhotoUrl %>" alt="GIF">
                                            <% } %>
                                            <label class="delete-overlay">
                                                <input type="checkbox" name="delete_live_photo" value="true">
                                                <span>Видалити</span>
                                            </label>
                                        </div>
                                    <% } else { %><p style="color: var(--text-muted); font-size: 13px;">Відсутнє</p><% } %>

                                    <label style="margin-top: 15px; display: block; font-weight: 600; font-size: 14px;">Замінити "живе" фото</label>
                                    <div class="file-upload-wrapper" style="padding: 15px;">
                                        <input type="file" id="livePhotoFile" name="livePhotoFile" accept="image/gif,video/*">
                                        <div class="file-upload-content">
                                            <i class="fa-solid fa-film" style="font-size: 24px; color: var(--brand-primary);"></i>
                                            <p style="font-size: 13px; margin-top: 5px;">Завантажити GIF або коротке відео</p>
                                        </div>
                                    </div>
                                    <div class="image-preview-container" id="livePhotoPreview"></div>
                                </div>
                            </div>

                            <!-- ХАРАКТЕРИСТИКИ -->
                            <div class="form-section">
                                <h3 class="form-section-title"><i class="fa-solid fa-list-ul"></i> Характеристики</h3>
                                <div class="form-row">
                                    <div class="admin-form-group">
                                        <label for="materials">Матеріали</label>
                                        <input type="text" id="materials" name="materials" value="<%= productData.materials ? productData.materials.join(', ') : '' %>" placeholder="Напр: Льон, бавовна">
                                    </div>
                                    <div class="admin-form-group">
                                        <label for="colors">Кольори</label>
                                        <input type="text" id="colors" name="colors" value="<%= productData.colors ? productData.colors.join(', ') : '' %>" placeholder="Напр: Білий, червоний">
                                    </div>
                                </div>
                                <div class="admin-form-group">
                                    <label for="care_instructions">Догляд за виробом</label>
                                    <textarea id="care_instructions" name="care_instructions" rows="2" placeholder="Як прати та прасувати..."><%= productData.care_instructions || '' %></textarea>
                                </div>
                                <div class="admin-form-group">
                                    <label for="tags">Теги <small>(через кому)</small></label>
                                    <input type="text" id="tags" name="tags" value="<%= productData.tags ? productData.tags.join(', ') : '' %>" placeholder="Напр: подарунок, ручна робота">
                                </div>
                            </div>

                            <!-- SEO -->
                            <div class="form-section">
                                <h3 class="form-section-title"><i class="fa-solid fa-magnifying-glass-chart"></i> SEO та відображення</h3>
                                <div class="admin-form-group">
                                    <label for="metaDescription">Meta Опис (для пошуку)</label>
                                    <div class="seo-input-group">
                                        <textarea id="metaDescription" name="metaDescription" rows="2" maxlength="170" placeholder="Короткий опис для Google..."><%= productData.metaDescription || '' %></textarea>
                                        <button type="button" id="generateMetaBtn" class="btn btn-secondary" title="Згенерувати за допомогою AI">
                                            <i class="fa-solid fa-wand-magic-sparkles"></i> AI
                                        </button>
                                    </div>
                                    <div id="metaCounter" style="font-size: 12px; margin-top: 5px; color: var(--text-muted); font-weight: 500;">0 / 170</div>
                                </div>
                                <div class="admin-form-group checkbox-group" style="margin-top: 10px;">
                                    <label>
                                        <input type="checkbox" name="isFeatured" <%= productData.isFeatured ? 'checked' : '' %>>
                                        <span>Показувати товар у блоці "Наші Хіти" на головній</span>
                                    </label>
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" id="saveBtn">
                                    <i class="fa-solid fa-save"></i> Зберегти зміни
                                </button>
                                <a href="/admin/products" class="btn btn-secondary">
                                    <i class="fa-solid fa-rotate-left"></i> Скасувати
                                </a>
                            </div>
                        </form>

                        <div class="danger-zone">
                            <h4 style="color: #b91c1c; margin-bottom: 8px; font-weight: 700;"><i class="fa-solid fa-triangle-exclamation"></i> Небезпечна зона</h4>
                            <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 15px;">Будьте обережні: видалення товару неможливо скасувати. Всі пов'язані файли будуть видалені з хмарного сховища.</p>
                            <button type="button" id="deleteProductBtn" class="btn btn-danger btn-sm">
                                <i class="fa-regular fa-trash-can"></i> Видалити товар назавжди
                            </button>
                        </div>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa-solid fa-circle-question" style="font-size: 40px; margin-bottom: 15px; color: var(--text-muted);"></i>
                        <h3>Товар не знайдено</h3>
                        <p>Можливо, він був видалений або посилання невірне.</p>
                        <a href="/admin/products" class="btn btn-primary" style="margin-top: 20px;">Повернутися до списку</a>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- Модальне вікно видалення -->
    <div id="confirmationModal" class="modal-overlay" style="display: none;">
        <div class="modal-dialog">
            <div class="modal-content">
                <button class="close-button" type="button">&times;</button>
                <div class="modal-body text-center">
                    <div class="warning-icon-wrapper" style="color: #ef4444; background: #fee2e2;">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    <h3 style="font-size: 20px; margin-bottom: 10px;">Видалити цей товар?</h3>
                    <p class="modal-subtext">Ви дійсно впевнені, що хочете видалити <strong><%= productData?.name %></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button id="cancelActionBtn" class="btn btn-secondary" type="button">Скасувати</button>
                    <button id="confirmDeleteBtn" class="btn btn-danger" type="button">Так, видалити</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
            const productId = '<%= productData?._id %>';
            const editForm = document.getElementById('editProductForm');
            
            // Мобільне меню
            document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
                document.querySelector('.admin-sidebar').classList.toggle('active');
            });

            // SEO Лічильник
            const metaInput = document.getElementById('metaDescription');
            const counter = document.getElementById('metaCounter');
            const updateCounter = () => {
                const len = metaInput.value.length;
                counter.textContent = `${len} / 170 символів`;
                counter.style.color = len > 170 ? '#ef4444' : 'var(--text-muted)';
            };
            metaInput?.addEventListener('input', updateCounter);
            updateCounter();

            // AI Генерація мета-опису
            document.getElementById('generateMetaBtn')?.addEventListener('click', async function() {
                const name = document.getElementById('name').value.trim();
                const desc = document.getElementById('description').value.trim();
                if(!name || !desc) return alert('Заповніть назву та опис товару!');
                
                this.disabled = true;
                const original = this.innerHTML;
                this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

                try {
                    const res = await fetch('/admin/generate-meta-description', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
                        body: JSON.stringify({ productName: name, productDescription: desc })
                    });
                    const data = await res.json();
                    if(data.metaDescription) {
                        metaInput.value = data.metaDescription;
                        updateCounter();
                        metaInput.style.borderColor = 'var(--brand-primary)';
                        setTimeout(() => metaInput.style.borderColor = '', 1000);
                    } else {
                        alert('Не вдалося згенерувати опис. Спробуйте ще раз.');
                    }
                } catch(e) { 
                    console.error(e);
                    alert('Помилка при запиті до AI.');
                } finally {
                    this.disabled = false;
                    this.innerHTML = original;
                }
            });

            // Прев'ю нових фото
            const imgInput = document.getElementById('imageFiles');
            const imgPreview = document.getElementById('newImagePreview');
            let selectedFiles = [];

            imgInput?.addEventListener('change', function() {
                const files = Array.from(this.files);
                // Ліміт на 10 фото сумарно з новими
                selectedFiles = [...selectedFiles, ...files].slice(0, 10);
                renderPreviews();
                this.value = '';
            });

            function renderPreviews() {
                imgPreview.innerHTML = '';
                selectedFiles.forEach((file, idx) => {
                    const reader = new FileReader();
                    reader.onload = e => {
                        const div = document.createElement('div');
                        div.className = 'image-preview-item';
                        div.innerHTML = `
                            <img src="${e.target.result}">
                            <button type="button" class="btn-remove-preview" data-idx="${idx}" title="Видалити">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        `;
                        div.querySelector('button').onclick = () => {
                            selectedFiles.splice(idx, 1);
                            renderPreviews();
                        };
                        imgPreview.appendChild(div);
                    };
                    reader.readAsDataURL(file);
                });
            }

            // Живе фото прев'ю
            const liveInput = document.getElementById('livePhotoFile');
            const livePreview = document.getElementById('livePhotoPreview');
            liveInput?.addEventListener('change', function() {
                livePreview.innerHTML = '';
                if(!this.files[0]) return;
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.className = 'image-preview-item';
                    if(this.files[0].type.startsWith('video')) {
                        div.innerHTML = `<video src="${e.target.result}" muted loop autoplay></video>`;
                    } else {
                        div.innerHTML = `<img src="${e.target.result}">`;
                    }
                    // Додаємо кнопку видалення прев'ю
                    const delBtn = document.createElement('button');
                    delBtn.className = 'btn-remove-preview';
                    delBtn.innerHTML = '&times;';
                    delBtn.onclick = () => {
                        liveInput.value = '';
                        livePreview.innerHTML = '';
                    };
                    div.appendChild(delBtn);
                    livePreview.appendChild(div);
                };
                reader.readAsDataURL(this.files[0]);
            });

            // Збереження форми через AJAX (Fetch)
            editForm?.addEventListener('submit', async function(e) {
                e.preventDefault();
                const saveBtn = document.getElementById('saveBtn');
                saveBtn.disabled = true;
                const originalHtml = saveBtn.innerHTML;
                saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Збереження...';

                const formData = new FormData(this);
                // Очищаємо дефолтне значення з інпуту і додаємо наші selectedFiles
                formData.delete('imageFiles');
                selectedFiles.forEach(file => formData.append('imageFiles', file));

                try {
                    const res = await fetch(`/admin/products/${productId}?_method=PUT`, {
                        method: 'POST', // POST + _method=PUT для multer
                        body: formData
                    });
                    
                    if(res.ok) {
                        window.location.href = '/admin/products';
                    } else {
                        const errData = await res.json().catch(() => ({}));
                        alert('Помилка при збереженні: ' + (errData.message || 'Спробуйте пізніше.'));
                        saveBtn.disabled = false;
                        saveBtn.innerHTML = originalHtml;
                    }
                } catch(err) { 
                    console.error(err);
                    alert('Помилка підключення до сервера.');
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = originalHtml;
                }
            });

            // Логіка модального вікна видалення
            const modal = document.getElementById('confirmationModal');
            document.getElementById('deleteProductBtn')?.addEventListener('click', () => {
                modal.style.display = 'flex';
                setTimeout(() => modal.classList.add('show'), 10);
            });

            const closeM = () => {
                modal.classList.remove('show');
                setTimeout(() => modal.style.display = 'none', 300);
            };
            
            modal?.querySelector('.close-button').addEventListener('click', closeM);
            document.getElementById('cancelActionBtn')?.addEventListener('click', closeM);
            window.addEventListener('click', (e) => { if (e.target === modal) closeM(); });

            document.getElementById('confirmDeleteBtn')?.addEventListener('click', async function() {
                this.disabled = true;
                this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Видаляємо...';
                
                try {
                    const res = await fetch(`/admin/products/${productId}/delete`, {
                        method: 'POST',
                        headers: { 'CSRF-Token': csrfToken }
                    });
                    if(res.ok) {
                        window.location.href = '/admin/products';
                    } else {
                        alert('Не вдалося видалити товар.');
                        this.disabled = false;
                        this.innerHTML = 'Так, видалити';
                    }
                } catch(e) { 
                    console.error(e);
                    alert('Помилка видалення.');
                    this.disabled = false;
                    this.innerHTML = 'Так, видалити';
                }
            });
        });
    </script>
</body>
</html>